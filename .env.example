BERRYBRAIN_ENV=local
BERRYBRAIN_API_HOST=0.0.0.0
BERRYBRAIN_API_PORT=8000
BERRYBRAIN_API_URL=http://localhost:8000
BERRYBRAIN_INTERNAL_API_URL=http://api:8000
BERRYBRAIN_WEB_PORT=3000
BERRYBRAIN_VAULT_PATH=/app/vault
BERRYBRAIN_VAULT_WATCHER_ENABLED=true
BERRYBRAIN_VAULT_WATCHER_INTERVAL_SECONDS=10
BERRYBRAIN_DATABASE_URL=sqlite:////app/data/sqlite/berrybrain.db
BERRYBRAIN_JOBS_PATH=/app/data/jobs
BERRYBRAIN_LOG_PATH=/app/data/logs
BERRYBRAIN_OLLAMA_BASE_URL=http://localhost:11434
BERRYBRAIN_MAIN_MODEL=qwen3:8b
BERRYBRAIN_FAST_MODEL=gemma3:4b
BERRYBRAIN_EMBEDDING_MODEL=bge-m3
BERRYBRAIN_REASONING_MODEL=deepseek-r1:8b
BERRYBRAIN_API_TOKEN=change-me-generate-a-random-api-token
BERRYBRAIN_ALLOWED_HOSTS=localhost,127.0.0.1,testserver,optlabs.com.br
BERRYBRAIN_MAX_REQUEST_BODY_BYTES=26214400
BERRYBRAIN_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://optlabs.com.br
BERRYBRAIN_BACKUP_PATH=/app/data/backups
BERRYBRAIN_PUBLIC_APP_URL=http://localhost:3000
BERRYBRAIN_BACKEND_URL=http://localhost:8000
BERRYBRAIN_SESSION_SECRET=change-me-with-32-plus-random-bytes
BERRYBRAIN_SESSION_COOKIE_NAME=bb_session
BERRYBRAIN_SESSION_SECURE_COOKIE=false
BERRYBRAIN_CSRF_COOKIE_NAME=bb_csrf
BERRYBRAIN_REQUIRE_AUTH=true
BERRYBRAIN_DONATION_URL=

# Set these in deployments mounted at /berrybrain.
NEXT_PUBLIC_BERRYBRAIN_API_URL=/berrybrain
NEXT_PUBLIC_BERRYBRAIN_BASE_PATH=/berrybrain
NEXT_PUBLIC_BERRYBRAIN_ASSET_PREFIX=/berrybrain
BERRYBRAIN_AUTH_RATE_LIMIT_WINDOW_SECONDS=900
BERRYBRAIN_AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
BERRYBRAIN_AUTH_LOCKOUT_MINUTES=15
BERRYBRAIN_AUTH_OTP_TTL_MINUTES=10
BERRYBRAIN_AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
BERRYBRAIN_ADMIN_EMAIL=admin@local.berrybrain

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=contato@optlabs.com.br
