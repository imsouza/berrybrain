BERRYBRAIN_ENV=production
BERRYBRAIN_API_HOST=0.0.0.0
BERRYBRAIN_API_PORT=8000
BERRYBRAIN_INTERNAL_API_URL=http://api:8000
NEXT_PUBLIC_BERRYBRAIN_API_URL=/api
BERRYBRAIN_WEB_PORT=3000
BERRYBRAIN_VAULT_PATH=/app/vault
BERRYBRAIN_VAULT_WATCHER_ENABLED=true
BERRYBRAIN_VAULT_WATCHER_INTERVAL_SECONDS=30
BERRYBRAIN_DATABASE_URL=sqlite:////app/data/sqlite/berrybrain.db
BERRYBRAIN_JOBS_PATH=/app/data/jobs
BERRYBRAIN_LOG_PATH=/app/data/logs
BERRYBRAIN_BACKUP_PATH=/app/data/backups
BERRYBRAIN_OLLAMA_BASE_URL=http://192.168.3.20:11434
BERRYBRAIN_MAIN_MODEL=qwen3:14b
BERRYBRAIN_FAST_MODEL=gemma3:4b
BERRYBRAIN_EMBEDDING_MODEL=bge-m3
BERRYBRAIN_REASONING_MODEL=qwen3:14b
BERRYBRAIN_API_TOKEN=
BERRYBRAIN_CORS_ORIGINS=*

# Domain and SSL
BERRYBRAIN_DOMAIN=berrybrain.exemplo.com
BERRYBRAIN_PROXY_HTTP=80
BERRYBRAIN_PROXY_HTTPS=443
BERRYBRAIN_LETSENCRYPT_EMAIL=admin@berrybrain.exemplo.com
